<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#FFFFFF" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        
        <TextView android:id="@+id/lblFormTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="NEW HARVEST RECORD" android:textSize="20sp" android:textStyle="bold" android:textColor="#1B5E20"/>

        <EditText android:id="@+id/editBlockId" android:layout_width="match_parent" android:layout_height="60dp" 
            android:hint="Block ID (e.g. A1)" android:inputType="textCapCharacters" android:layout_marginTop="15dp"/>

        <!-- RIPE BUNCHES: SLIDER + MANUAL -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ripe Bunches" android:layout_marginTop="20dp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <SeekBar android:id="@+id/seekRipe" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="100"/>
            <EditText android:id="@+id/txtRipeManual" android:layout_width="60dp" android:layout_height="wrap_content" 
                android:inputType="number" android:text="0" android:gravity="center" android:textSize="20sp" android:background="@null"/>
        </LinearLayout>

        <!-- EMPTY BUNCHES: STILL +/- (Usually low numbers) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty Bunches" android:layout_marginTop="15dp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <Button android:id="@+id/btnMinusEmpty" android:layout_width="60dp" android:layout_height="wrap_content" android:text="-"/>
            <TextView android:id="@+id/txtEmptyCount" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="0" android:gravity="center" android:textSize="22sp"/>
            <Button android:id="@+id/btnPlusEmpty" android:layout_width="60dp" android:layout_height="wrap_content" android:text="+"/>
        </LinearLayout>

        <ImageView android:id="@+id/imgPreview" android:layout_width="150dp" android:layout_height="150dp" 
            android:layout_gravity="center" android:layout_marginTop="20dp" android:background="#F0F0F0" android:src="@android:drawable/ic_menu_camera"/>
        <Button android:id="@+id/btnPhoto" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Take Harvest Photo" android:layout_marginTop="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="30dp">
            <Button android:id="@+id/btnCancel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="70dp" android:text="CANCEL" android:backgroundTint="#D32F2F" android:textColor="#FFFFFF"/>
            <View android:layout_width="16dp" android:layout_height="1dp"/>
            <Button android:id="@+id/btnSave" android:layout_width="0dp" android:layout_weight="1" android:layout_height="70dp" android:text="SAVE" android:backgroundTint="#2E7D32" android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>